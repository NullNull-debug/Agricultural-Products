<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.farmproduct.mapper.ReviewMapper">
    <select id="findByProductId" resultType="com.farmproduct.entity.Review">
        SELECT * FROM reviews WHERE product_id = #{productId}
    </select>
    <select id="findByUserId" resultType="com.farmproduct.entity.Review">
        SELECT * FROM reviews WHERE user_id = #{userId}
    </select>
</mapper>